# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side admin operations only — never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://autofx.ae

# Stripe Payment Links (create in Stripe Dashboard → Payment Links)
# These are public URLs, safe to expose
NEXT_PUBLIC_STRIPE_BRONZE_LINK=https://buy.stripe.com/your-bronze-link
NEXT_PUBLIC_STRIPE_SILVER_LINK=https://buy.stripe.com/your-silver-link
NEXT_PUBLIC_STRIPE_GOLD_LINK=https://buy.stripe.com/your-gold-link
