// AutoFX Copy Trading Platform — Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Authentication ───────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  passwordHash      String
  phone             String?
  country           String?
  avatarUrl         String?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subscription      Subscription?
  brokerAccount     BrokerAccount?
  payments          Payment[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  activityLogs      ActivityLog[]
  sessions          Session[]
  verificationTokens VerificationToken[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String              @id @default(cuid())
  userId    String
  token     String              @unique
  type      VerificationTokenType
  expiresAt DateTime
  createdAt DateTime            @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FACTOR
}

// ─── Packages ─────────────────────────────────────────────────────────────

model Package {
  id              String   @id @default(cuid())
  name            String   @unique
  tier            PackageTier @unique
  monthlyPrice    Decimal  @db.Decimal(10, 2)
  minDeposit      Decimal  @db.Decimal(12, 2)
  maxRiskPercent  Decimal  @db.Decimal(5, 2)
  lotSizeMultiplier Decimal @db.Decimal(5, 4)
  features        String[]
  stripePriceId   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]

  @@map("packages")
}

enum PackageTier {
  BRONZE
  SILVER
  GOLD
}

// ─── Subscriptions ────────────────────────────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  packageId           String
  status              SubscriptionStatus @default(PENDING_PAYMENT)
  stripeSubscriptionId String?           @unique
  stripeCustomerId    String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  gracePeriodEnd      DateTime?
  cancelledAt         DateTime?
  cancelReason        String?
  activatedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])
  payments Payment[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
  CANCELLED
  PAST_DUE
  GRACE_PERIOD
}

// ─── Payments ─────────────────────────────────────────────────────────────

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  subscriptionId      String?
  stripePaymentIntentId String?     @unique
  stripeInvoiceId     String?       @unique
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  status              PaymentStatus @default(PENDING)
  description         String?
  invoiceUrl          String?
  invoiceNumber       String?       @unique
  failureReason       String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

// ─── Broker Accounts ──────────────────────────────────────────────────────

model BrokerAccount {
  id                String              @id @default(cuid())
  userId            String              @unique
  brokerId          String
  accountNumber     String
  passwordEncrypted String
  server            String
  accountName       String?
  currency          String?
  balance           Decimal?            @db.Decimal(15, 2)
  equity            Decimal?            @db.Decimal(15, 2)
  leverage          Int?
  status            BrokerAccountStatus @default(PENDING_VERIFICATION)
  verifiedAt        DateTime?
  lastSyncAt        DateTime?
  verificationError String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker Broker @relation(fields: [brokerId], references: [id])
  copiedTrades CopiedTrade[]

  @@map("broker_accounts")
}

enum BrokerAccountStatus {
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  SUSPENDED
  INVALID_CREDENTIALS
  INSUFFICIENT_BALANCE
  DISCONNECTED
}

model Broker {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  servers     BrokerServer[]
  accounts    BrokerAccount[]
  createdAt   DateTime @default(now())

  @@map("brokers")
}

model BrokerServer {
  id        String  @id @default(cuid())
  brokerId  String
  name      String
  host      String
  port      Int     @default(443)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@map("broker_servers")
}

// ─── Copy Trading ─────────────────────────────────────────────────────────

model MasterAccount {
  id              String   @id @default(cuid())
  brokerId        String
  accountNumber   String
  server          String
  passwordEncrypted String
  isActive        Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trades MasterTrade[]

  @@map("master_accounts")
}

model MasterTrade {
  id              String      @id @default(cuid())
  masterAccountId String
  ticket          String
  symbol          String
  type            TradeType
  openTime        DateTime
  closeTime       DateTime?
  openPrice       Decimal     @db.Decimal(15, 5)
  closePrice      Decimal?    @db.Decimal(15, 5)
  lotSize         Decimal     @db.Decimal(10, 2)
  stopLoss        Decimal?    @db.Decimal(15, 5)
  takeProfit      Decimal?    @db.Decimal(15, 5)
  profit          Decimal?    @db.Decimal(15, 2)
  status          TradeStatus @default(OPEN)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  masterAccount  MasterAccount @relation(fields: [masterAccountId], references: [id])
  copiedTrades   CopiedTrade[]

  @@map("master_trades")
}

model CopiedTrade {
  id                String      @id @default(cuid())
  masterTradeId     String
  brokerAccountId   String
  ticket            String?
  symbol            String
  type              TradeType
  lotSize           Decimal     @db.Decimal(10, 2)
  openPrice         Decimal?    @db.Decimal(15, 5)
  closePrice        Decimal?    @db.Decimal(15, 5)
  profit            Decimal?    @db.Decimal(15, 2)
  status            TradeStatus @default(PENDING)
  errorMessage      String?
  copiedAt          DateTime    @default(now())
  closedAt          DateTime?
  updatedAt         DateTime    @updatedAt

  masterTrade   MasterTrade   @relation(fields: [masterTradeId], references: [id])
  brokerAccount BrokerAccount @relation(fields: [brokerAccountId], references: [id])

  @@map("copied_trades")
}

enum TradeType {
  BUY
  SELL
  BUY_LIMIT
  SELL_LIMIT
  BUY_STOP
  SELL_STOP
}

enum TradeStatus {
  PENDING
  OPEN
  CLOSED
  CANCELLED
  ERROR
}

// ─── Notifications ────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  REGISTRATION
  EMAIL_VERIFIED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_REJECTED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_EXPIRING
  TRADE_COPIED
  BROKER_CONNECTED
  BROKER_DISCONNECTED
  SYSTEM_ANNOUNCEMENT
  SUPPORT_REPLY
}

// ─── Support ──────────────────────────────────────────────────────────────

model SupportTicket {
  id         String        @id @default(cuid())
  userId     String
  subject    String
  status     TicketStatus  @default(OPEN)
  priority   TicketPriority @default(NORMAL)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  senderType SenderType
  message   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SenderType {
  CLIENT
  ADMIN
}

// ─── Administration ───────────────────────────────────────────────────────

model Admin {
  id           String      @id @default(cuid())
  fullName     String
  email        String      @unique
  username     String      @unique
  passwordHash String
  role         AdminRole   @default(CUSTOMER_SUPPORT)
  status       AdminStatus @default(ACTIVE)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  activityLogs ActivityLog[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  OPERATIONS_ADMIN
  CUSTOMER_SUPPORT
  FINANCE_ADMIN
  READ_ONLY_ADMIN
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ─── Activity Logs ────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  adminId    String?
  action     String
  entity     String?
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  result     String   @default("SUCCESS")
  createdAt  DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

// ─── Content / CMS ────────────────────────────────────────────────────────

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

model TutorialVideo {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  thumbnailUrl String?
  category    String   @default("general")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tutorial_videos")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
